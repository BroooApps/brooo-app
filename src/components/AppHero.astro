---
import type { App } from '../data/apps';
interface Props { app: App; }
const { app } = Astro.props;
if (!app.hero) throw new Error(`AppHero requires app.hero for slug ${app.slug}`);

const statusLabel =
  app.status === 'live' ? '● LIVE ON GOOGLE PLAY' :
  app.status === 'beta' ? `○ BETA · SHIPS ${app.betaDate ?? ''}` :
  '○ COOKING';

const primaryCta =
  app.status === 'live' && app.playStoreUrl
    ? { label: '[ INSTALL ON PLAY STORE ↗ ]', href: app.playStoreUrl, external: true }
    : { label: '[ JOIN THE BETA ↗ ]', href: 'mailto:hello@brooo.app?subject=Beta access', external: false };
---
<section class="apphero section section--bordered">
  <div class="container apphero__grid">
    <div class="apphero__text">
      <div class="apphero__badge">{app.wordmark}</div>
      <div class="apphero__status accent">{statusLabel}</div>
      <h1 class="h-display apphero__headline" set:html={app.hero.headline.replace(/\n/g, '<br/>')}></h1>
      <p class="apphero__blurb">{app.hero.blurb}</p>
      <div class="apphero__ctas">
        <a href={primaryCta.href} class="btn btn--primary" {...(primaryCta.external ? { target: '_blank', rel: 'noopener' } : {})}>{primaryCta.label}</a>
        <a href="#screenshots" class="btn btn--ghost">[ SCREENSHOTS ↓ ]</a>
      </div>
    </div>
    <div class="apphero__media">
      <img src={app.hero.screenshot} alt={`${app.name} — hero screenshot`} loading="eager" />
    </div>
  </div>
</section>

<style>
  .apphero { padding-top: 64px; padding-bottom: 48px; }
  .apphero__grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .apphero__badge {
    display: inline-block;
    background: var(--fg);
    color: var(--bg);
    padding: 6px 12px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 20px;
  }
  .apphero__status {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }
  .apphero__headline { margin-bottom: 20px; }
  .apphero__blurb {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.6;
    max-width: 460px;
    margin-bottom: 28px;
  }
  .apphero__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .apphero__media {
    background: var(--surface);
    border: var(--border-w) solid var(--border);
    aspect-ratio: 9 / 16;
    max-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .apphero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (max-width: 900px) {
    .apphero__grid { grid-template-columns: 1fr; }
    .apphero__media { max-height: 540px; }
  }
</style>
