---
// Top navigation — used on every page.
---
<nav class="nav">
  <div class="nav__inner container">
    <a href="/" class="nav__brand">BROOOAPPS<span class="accent">.</span></a>
    <ul class="nav__links">
      <li><a href="/#apps">apps</a></li>
      <li><a href="https://medium.com/@swapniltiwari775" target="_blank" rel="noopener" class="muted">// blog ↗</a></li>
      <li><a href="mailto:hello@brooo.app" class="muted">// hello@brooo.app</a></li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    border-bottom: var(--border-w) solid var(--border);
    background: var(--bg);
  }
  .nav__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 18px;
    padding-bottom: 18px;
    font-size: 13px;
    font-weight: 700;
  }
  .nav__brand {
    border-bottom: 0;
    font-weight: 900;
  }
  .nav__brand:hover { background: transparent; color: inherit; }
  .nav__links {
    display: flex;
    gap: 24px;
    font-weight: 500;
  }
  .nav__links a { border-bottom: 0; }
  .nav__links a:hover { background: transparent; color: var(--accent); }
  @media (max-width: 700px) {
    .nav__inner { flex-direction: column; align-items: flex-start; gap: 12px; }
    .nav__links { flex-wrap: wrap; gap: 16px; font-size: 12px; }
  }
</style>
