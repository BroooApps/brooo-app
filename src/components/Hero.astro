---
// Homepage hero.
---
<section class="hero section--lg section--bordered">
  <div class="container">
    <div class="hero__label accent">// EST. 2026 · INDIE · INDIA</div>
    <h1 class="h-display hero__headline">small apps for<br/>better habits.</h1>
    <p class="hero__blurb">tiny self-improvement apps built by one indie maker who needed them first. shipped on Google Play. privacy-first by default.</p>
    <div class="hero__ctas">
      <a href="#apps" class="btn btn--primary">[ SEE THE APPS ↓ ]</a>
      <a href="https://twitter.com/tiwariswapnil_" target="_blank" rel="noopener" class="btn btn--ghost">[ FOLLOW ON X ↗ ]</a>
    </div>
  </div>
</section>

<style>
  .hero { padding-top: 80px; padding-bottom: 64px; }
  .hero__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    margin-bottom: 20px;
  }
  .hero__headline { margin-bottom: 24px; }
  .hero__blurb {
    font-size: 15px;
    color: var(--muted);
    max-width: 540px;
    line-height: 1.6;
    margin-bottom: 32px;
  }
  .hero__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
</style>
