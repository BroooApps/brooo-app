---
import type { App } from '../data/apps';
import SectionLabel from './SectionLabel.astro';
interface Props { app: App; }
const { app } = Astro.props;
if (!app.screenshots?.length) throw new Error(`Screenshots requires app.screenshots for slug ${app.slug}`);
---
<section id="screenshots" class="screenshots section section--bordered">
  <div class="container">
    <SectionLabel text="SCREENSHOTS" />
    <div class="screenshots__grid">
      {app.screenshots.map((src, i) => (
        <div class="screenshots__cell">
          <img src={src} alt={`${app.name} — screenshot ${i + 1}`} loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .screenshots__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .screenshots__cell {
    background: var(--surface);
    border: var(--border-w) solid var(--border);
    aspect-ratio: 9 / 19;
    overflow: hidden;
  }
  .screenshots__cell img { width: 100%; height: 100%; object-fit: cover; }
  @media (max-width: 900px) {
    .screenshots__grid {
      grid-template-columns: repeat(4, 80%);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 8px;
    }
    .screenshots__cell { scroll-snap-align: start; }
  }
</style>
