---
interface Props {
  title: string;
  description: string;
  ogImage?: string;        // relative path under /og, e.g. "/og/sutts.png"
  canonical?: string;      // full URL, optional
}

const { title, description, ogImage = '/og/default.png', canonical } = Astro.props;
const siteUrl = 'https://brooo.app';
const fullOg = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={fullOg} />
    <meta property="og:site_name" content="BroooApps" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOg} />

    <!-- Preload primary font weight -->
    <link rel="preload" href="/fonts/jetbrains-mono-latin-400.woff2" as="font" type="font/woff2" crossorigin />

    <style is:global>
      @import '/src/styles/global.css';
    </style>

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />
  </body>
</html>
