---
import "../styles/global.css";
const { title = "BroooApps", description = "Tools for getting better at being you." } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <slot />
      <footer>
        © {new Date().getFullYear()} BroooApps · <a href="/">Home</a> · <a href="mailto:swapniltiwari775@gmail.com">Contact</a>
      </footer>
    </main>
  </body>
</html>
