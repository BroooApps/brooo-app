---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import StatsStrip from '../components/StatsStrip.astro';
import AppsGrid from '../components/AppsGrid.astro';
import Footer from '../components/Footer.astro';
---
<Base
  title="BroooApps — small apps for better habits"
  description="Tiny self-improvement Android apps built by one indie maker. Ember, Dearly, Randomizer. Privacy-first by default."
  ogImage="/og/default.png"
>
  <Nav />
  <main id="main">
    <Hero />
    <StatsStrip />
    <AppsGrid />
  </main>
  <Footer />
</Base>
